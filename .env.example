PORT=3000

# Database – dedicated OTA container (docker-compose service: db)
DB_HOST=ota_db
DB_USER=ota_user
DB_PASS=your_db_password
DB_ROOT_PASS=your_root_password
DB_NAME=ota_firmware_db

# Security
GITHUB_WEBHOOK_SECRET=your_webhook_secret
SESSION_SECRET=generate_with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CORS_ORIGIN=http://localhost:3000
