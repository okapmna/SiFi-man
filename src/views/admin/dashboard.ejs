<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'dashboard' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2">Dashboard Overview</h1>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card stat-card-dark">
                <div class="stat-icon"><i class="bi bi-cpu"></i></div>
                <div class="stat-label">Device Types</div>
                <div class="stat-value"><%= typeof totalDevices !== 'undefined' ? totalDevices : 0 %></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card stat-card-accent">
                <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
                <div class="stat-label">Firmwares</div>
                <div class="stat-value"><%= typeof totalFirmwares !== 'undefined' ? totalFirmwares : 0 %></div>
            </div>
        </div>
    </div>

    <!-- Recent Uploads Table -->
    <div class="card">
        <div class="card-header">Recent Uploads</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Device Type</th>
                            <th>Version</th>
                            <th>Filename</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentUploads === 'undefined' || recentUploads.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-3">No firmwares uploaded yet</td>
                            </tr>
                        <% } else { %>
                            <% recentUploads.forEach(function(fw) { %>
                                <tr>
                                    <td><%= fw.id %></td>
                                    <td><span class="badge bg-secondary"><%= fw.type_name %></span></td>
                                    <td><%= fw.version %></td>
                                    <td><%= fw.filename %></td>
                                    <td><%= new Date(fw.created_at).toLocaleString() %></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>



<%- include('partials/footer') %>

