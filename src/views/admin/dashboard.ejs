<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'dashboard' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom" style="border-color: #333 !important;">
        <h1 class="h2">Dashboard Overview</h1>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-cpu"></i> Device Types</h5>
                    <p class="card-text fs-2 fw-bold"><%= typeof totalDevices !== 'undefined' ? totalDevices : 0 %></p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-box-seam"></i> Firmwares</h5>
                    <p class="card-text fs-2 fw-bold"><%= typeof totalFirmwares !== 'undefined' ? totalFirmwares : 0 %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">Upload Activity</div>
                <div class="card-body">
                    <canvas id="uploadChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Uploads Table -->
    <div class="card">
        <div class="card-header">Recent Uploads</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-striped mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Device Type</th>
                            <th>Version</th>
                            <th>Filename</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentUploads === 'undefined' || recentUploads.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-3">No firmwares uploaded yet</td>
                            </tr>
                        <% } else { %>
                            <% recentUploads.forEach(function(fw) { %>
                                <tr>
                                    <td><%= fw.id %></td>
                                    <td><span class="badge bg-secondary"><%= fw.type_name %></span></td>
                                    <td><%= fw.version %></td>
                                    <td><%= fw.filename %></td>
                                    <td><%= new Date(fw.created_at).toLocaleString() %></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
    /**
     * Dashboard Charts and Interactions
     */
    document.addEventListener("DOMContentLoaded", function() {
        // Safe access to EJS variables for JS
        const totalFirmwaresCount = Number('<%= typeof totalFirmwares !== "undefined" ? totalFirmwares : 0 %>');
        const ctx = document.getElementById('uploadChart');

        if (ctx && typeof Chart !== 'undefined') {
            new Chart(ctx.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Firmware Uploads',
                        data: [0, 2, 1, 3, totalFirmwaresCount, 0],
                        backgroundColor: 'rgba(13, 110, 253, 0.5)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#333' },
                            ticks: { color: '#adb5bd' }
                        },
                        x: {
                            grid: { color: '#333' },
                            ticks: { color: '#adb5bd' }
                        }
                    },
                    plugins: {
                        legend: {
                            labels: { color: '#fff' }
                        }
                    }
                }
            });
        }
    });
</script>

<%- include('partials/footer') %>

