<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'firmwares' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2"><i class="bi bi-box-seam me-2"></i>Manage Firmwares</h1>
        <a href="/admin/upload" class="btn btn-primary">
            <i class="bi bi-cloud-arrow-up"></i> Upload New Firmware
        </a>
    </div>

    <!-- Flash Messages -->
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Filter Bar -->
    <div class="card mb-4">
        <div class="card-body py-2">
            <form method="GET" action="/admin/firmwares" class="d-flex align-items-center gap-3">
                <label class="form-label mb-0 text-nowrap"><i class="bi bi-funnel"></i> Filter by Device:</label>
                <select name="device" class="form-select form-select-sm form-select-device-filter" style="max-width: 260px;">
                    <option value="">All Device Types</option>
                    <% deviceTypes.forEach(function(dt) { %>
                        <option value="<%= dt.type_name %>" <%= deviceFilter === dt.type_name ? 'selected' : '' %>><%= dt.type_name %></option>
                    <% }); %>
                </select>
                <% if (deviceFilter) { %>
                    <a href="/admin/firmwares" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                <% } %>
                <span class="ms-auto text-muted small d-flex align-items-center gap-2">
                    <% if (isSupabase) { %>
                        <button id="btnSyncSupabase" class="btn btn-sm btn-outline-info" title="Sync firmware ke Supabase Storage">
                            <i class="bi bi-cloud-arrow-up"></i> Sync to Supabase
                        </button>
                    <% } %>
                    <span id="firmwareCount">–</span> firmware(s)
                </span>
            </form>
        </div>
    </div>

    <!-- Firmwares Table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Device Type</th>
                            <th>Version</th>
                            <th>File</th>
                            <th>Size</th>
                            <th>Checksum</th>
                            <th>Status</th>
                            <th>Notes</th>
                            <th>Uploaded By</th>
                            <th>Source Repo</th>
                            <th>Uploaded</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="firmwaresTableBody">
                        <% if (typeof firmwares === 'undefined' || firmwares.length === 0) { %>
                            <tr><td colspan="11" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No firmwares found</td></tr>
                        <% } else { %>
                            <% firmwares.forEach(function(fw) { %>
                                <tr class="fw-row" style="cursor:pointer;"
                                    data-id="<%= fw.id %>"
                                    data-device="<%= fw.type_name %>"
                                    data-version="<%= fw.version %>"
                                    data-filename="<%= fw.filename %>"
                                    data-size="<%= fw.file_size !== null && fw.file_size !== undefined ? fw.file_size : '' %>"
                                    data-checksum="<%= fw.checksum || '' %>"
                                    data-status="<%= fw.is_active ? 'Active' : 'Inactive' %>"
                                    data-notes="<%= fw.notes || '' %>"
                                    data-uploadedby="<%= fw.uploaded_by || '' %>"
                                    data-sourcerepo="<%= fw.source_repo || '' %>"
                                    data-createdat="<%= new Date(fw.created_at).toISOString() %>"
                                    data-filepath="<%= fw.file_path || '' %>">
                                    <td><span class="badge bg-primary"><%= fw.type_name %></span></td>
                                    <td><code><%= fw.version %></code></td>
                                    <td class="text-truncate" style="max-width:160px;" title="<%= fw.filename %>"><%= fw.filename %></td>
                                    <td>
                                        <% if (fw.file_size !== null && fw.file_size !== undefined) { %>
                                            <% if (fw.file_size < 1024) { %>
                                                <%= fw.file_size %> B
                                            <% } else if (fw.file_size < 1048576) { %>
                                                <%= (fw.file_size / 1024).toFixed(1) %> KB
                                            <% } else { %>
                                                <%= (fw.file_size / 1048576).toFixed(1) %> MB
                                            <% } %>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </td>
                                    <td><code class="text-muted small" title="<%= fw.checksum || '' %>"><%= fw.checksum ? fw.checksum.substring(0, 12) + '…' : 'N/A' %></code></td>
                                    <td>
                                        <% if (fw.is_active) { %>
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Inactive</span>
                                        <% } %>
                                    </td>
                                    <td class="small"><%= fw.notes ? fw.notes.substring(0, 40) + (fw.notes.length > 40 ? '…' : '') : '–' %></td>
                                    <td class="small">
                                        <% if (fw.uploaded_by) { %>
                                            <i class="bi bi-person-fill me-1"></i><%= fw.uploaded_by %>
                                        <% } else { %>
                                            –
                                        <% } %>
                                    </td>
                                    <td class="small text-muted" title="<%= fw.source_repo || '' %>"><%= fw.source_repo ? (fw.source_repo.substring(0, 20) + (fw.source_repo.length > 20 ? '…' : '')) : '–' %></td>
                                    <td class="small text-muted"><%= new Date(fw.created_at).toLocaleString() %></td>
                                    <td class="text-nowrap">
                                        <% if (fw.is_active) { %>
                                            <button class="btn btn-sm btn-success me-1" disabled title="Already active"><i class="bi bi-check-circle"></i></button>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-outline-success me-1 btn-activate-fw" data-id="<%= fw.id %>" title="Set as Active"><i class="bi bi-check-circle"></i></button>
                                        <% } %>
                                        <% if (fw.is_active) { %>
                                            <button class="btn btn-sm btn-outline-danger" disabled title="Cannot delete active firmware"><i class="bi bi-trash"></i></button>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-outline-danger btn-delete-fw" data-id="<%= fw.id %>" title="Delete firmware"><i class="bi bi-trash"></i></button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- Sync Result Modal -->
<% if (isSupabase) { %>
<div class="modal fade" id="syncResultModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cloud-arrow-up me-2"></i>Sync to Supabase</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="syncResultBody">
                <div class="text-center py-4" id="syncLoading">
                    <div class="spinner-border text-info mb-3" role="status"></div>
                    <p class="mb-0">Syncing firmware ke Supabase Storage...</p>
                </div>
                <div id="syncResultContent" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Firmware Detail Modal -->
<div class="modal fade" id="firmwareDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-info-circle me-2"></i>Firmware Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered mb-0">
                    <tbody>
                        <tr><th style="width:140px;" class="text-nowrap">Device Type</th><td><span class="badge bg-primary" id="detail-device"></span></td></tr>
                        <tr><th>Version</th><td><code id="detail-version"></code></td></tr>
                        <tr><th>Filename</th><td><code id="detail-filename"></code></td></tr>
                        <tr><th>File Path</th><td><small class="text-muted" id="detail-filepath"></small></td></tr>
                        <tr><th>File Size</th><td id="detail-size"></td></tr>
                        <tr><th>SHA256 Checksum</th><td><code style="word-break:break-all;" id="detail-checksum"></code></td></tr>
                        <tr><th>Status</th><td><span id="detail-status"></span></td></tr>
                        <tr><th>Notes</th><td id="detail-notes" style="white-space:pre-wrap;"></td></tr>
                        <tr><th>Uploaded By</th><td id="detail-uploadedby"></td></tr>
                        <tr><th>Source Repo</th><td><code id="detail-sourcerepo"></code></td></tr>
                        <tr><th>Uploaded At</th><td id="detail-createdat"></td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    const countEl = document.getElementById('firmwareCount');
    if (countEl) {
        countEl.textContent = '<%= typeof firmwares !== "undefined" ? firmwares.length : 0 %>';
    }

    async function activateFirmware(id, btn) {
        if (!confirm('Set this firmware as the active version for its device type?')) return;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const res = await fetch('/admin/firmwares/' + id + '/activate', { method: 'PATCH' });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                alert('Error: ' + (data.error || 'Unknown error'));
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-circle"></i>';
            }
        } catch (e) {
            alert('Network error. Please try again.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle"></i>';
        }
    }

    async function deleteFirmware(id, btn) {
        if (!confirm('Delete this firmware? This will also remove the file from disk. This action cannot be undone.')) return;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const res = await fetch('/admin/firmwares/' + id, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                const row = btn.closest('tr');
                const tbody = row.closest('tbody');
                row.style.opacity = '0.4';
                row.style.transition = 'opacity 0.4s';
                setTimeout(function() {
                    row.remove();
                    if (tbody && tbody.querySelectorAll('tr').length === 0) {
                        tbody.innerHTML = '<tr><td colspan="11" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No firmwares found</td></tr>';
                    }
                }, 400);
                var cEl = document.getElementById('firmwareCount');
                cEl.textContent = parseInt(cEl.textContent) - 1;
            } else {
                alert('Error: ' + (data.error || 'Unknown error'));
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-trash"></i>';
            }
        } catch (e) {
            alert('Network error. Please try again.');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-trash"></i>';
        }
    }

    // Detail modal (initialized lazily — bootstrap loads after this script)
    var detailModal = null;
    document.querySelectorAll('.fw-row').forEach(function(row) {
        row.addEventListener('click', function(e) {
            if (e.target.closest('td:last-child') || e.target.closest('button')) return;
            if (!detailModal) {
                detailModal = new bootstrap.Modal(document.getElementById('firmwareDetailModal'));
            }
            document.getElementById('detail-device').textContent = row.getAttribute('data-device');
            document.getElementById('detail-version').textContent = row.getAttribute('data-version');
            document.getElementById('detail-filename').textContent = row.getAttribute('data-filename');
            document.getElementById('detail-filepath').textContent = row.getAttribute('data-filepath');
            var size = row.getAttribute('data-size');
            if (size) {
                var bytes = parseInt(size);
                if (bytes < 1024) size = bytes + ' B';
                else if (bytes < 1048576) size = (bytes / 1024).toFixed(1) + ' KB';
                else size = (bytes / 1048576).toFixed(1) + ' MB';
            } else {
                size = 'N/A';
            }
            document.getElementById('detail-size').textContent = size;
            document.getElementById('detail-checksum').textContent = row.getAttribute('data-checksum') || 'N/A';
            document.getElementById('detail-status').textContent = row.getAttribute('data-status');
            document.getElementById('detail-status').className = 'badge ' + (row.getAttribute('data-status') === 'Active' ? 'bg-success' : 'bg-secondary');
            document.getElementById('detail-notes').textContent = row.getAttribute('data-notes') || '–';
            document.getElementById('detail-uploadedby').textContent = row.getAttribute('data-uploadedby') || '–';
            document.getElementById('detail-sourcerepo').textContent = row.getAttribute('data-sourcerepo') || '–';
            var d = new Date(row.getAttribute('data-createdat'));
            document.getElementById('detail-createdat').textContent = d.toLocaleString();
            detailModal.show();
        });
    });

    // Bind activate buttons
    document.querySelectorAll('.btn-activate-fw').forEach(function(btn) {
        btn.addEventListener('click', function() {
            activateFirmware(this.getAttribute('data-id'), this);
        });
    });

    // Bind delete buttons
    document.querySelectorAll('.btn-delete-fw').forEach(function(btn) {
        btn.addEventListener('click', function() {
            deleteFirmware(this.getAttribute('data-id'), this);
        });
    });

    // Sync to Supabase
    var syncBtn = document.getElementById('btnSyncSupabase');
    if (syncBtn) {
        syncBtn.addEventListener('click', async function() {
            var modal = new bootstrap.Modal(document.getElementById('syncResultModal'));
            modal.show();

            var loading = document.getElementById('syncLoading');
            var content = document.getElementById('syncResultContent');
            loading.style.display = 'block';
            content.style.display = 'none';

            try {
                var res = await fetch('/admin/firmwares/sync', { method: 'POST' });
                var data = await res.json();

                loading.style.display = 'none';
                content.style.display = 'block';

                var html = '';
                if (data.error) {
                    html = '<div class="alert alert-danger">' + data.error + '</div>';
                } else {
                    html += '<div class="mb-3">';
                    html += '<span class="badge bg-success me-1">' + data.success.length + ' synced</span>';
                    html += '<span class="badge bg-secondary me-1">' + data.skipped.length + ' skipped</span>';
                    html += '<span class="badge bg-danger">' + data.failed.length + ' failed</span>';
                    html += '</div>';

                    if (data.success.length > 0) {
                        html += '<h6 class="text-success"><i class="bi bi-check-circle"></i> Synced</h6><ul class="small">';
                        data.success.forEach(function(p) { html += '<li>' + p + '</li>'; });
                        html += '</ul>';
                    }
                    if (data.skipped.length > 0) {
                        html += '<h6 class="text-secondary"><i class="bi bi-skip-forward"></i> Skipped (already exist)</h6><ul class="small">';
                        data.skipped.forEach(function(p) { html += '<li>' + p + '</li>'; });
                        html += '</ul>';
                    }
                    if (data.failed.length > 0) {
                        html += '<h6 class="text-danger"><i class="bi bi-x-circle"></i> Failed</h6><ul class="small">';
                        data.failed.forEach(function(f) { html += '<li>' + f.path + ' — ' + f.reason + '</li>'; });
                        html += '</ul>';
                    }
                }
                content.innerHTML = html;
            } catch (e) {
                loading.style.display = 'none';
                content.style.display = 'block';
                content.innerHTML = '<div class="alert alert-danger">Network error: ' + e.message + '</div>';
            }
        });
    }
</script>

<%- include('partials/footer') %>
