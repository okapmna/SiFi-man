<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'devices' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2">Manage Device Types</h1>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDeviceModal">
            <i class="bi bi-plus-circle"></i> Add Device Type
        </button>
    </div>

    <!-- Devices Table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Firmwares</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="devicesTableBody">
                        <!-- Table content will be rendered via JavaScript below to prevent IDE HTML linter errors -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script id="devices-data" type="application/json">
    <%- JSON.stringify(devices || []) %>
</script>

<script>
    // Memasukkan data dari server ke variabel JavaScript
    // Kita mengambil JSON dari tag script tipe "application/json" di atas
    // untuk menghindari error "Expression expected" pada JS linter VS Code.
    const devicesData = JSON.parse(document.getElementById('devices-data').textContent);
    const tbody = document.getElementById('devicesTableBody');

    if (devicesData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4">No device types found</td></tr>';
    } else {
        devicesData.forEach(function(device) {
            const tr = document.createElement('tr');
            
            const dateStr = new Date(device.created_at).toLocaleDateString();
            const descStr = device.description || '-';
            const rawDesc = device.description || '';
            
            let deleteBtn = '';
            if (device.firmware_count > 0) {
                deleteBtn = '<button class="btn btn-sm btn-outline-danger" onclick="deleteDevice(' + device.id + ')" disabled title="Cannot delete device with firmwares"><i class="bi bi-trash"></i></button>';
            } else {
                deleteBtn = '<button class="btn btn-sm btn-outline-danger" onclick="deleteDevice(' + device.id + ')"><i class="bi bi-trash"></i></button>';
            }

            tr.innerHTML = `
                <td>${device.id}</td>
                <td><span class="badge bg-primary">${device.type_name}</span></td>
                <td>${descStr}</td>
                <td>${device.firmware_count}</td>
                <td>${dateStr}</td>
                <td>
                    <button class="btn btn-sm btn-outline-info me-1" 
                        onclick="editDevice(this)" 
                        data-id="${device.id}" 
                        data-name="${device.type_name}" 
                        data-desc="${rawDesc}">
                        <i class="bi bi-pencil"></i>
                    </button>
                    ${deleteBtn}
                </td>
            `;
            tbody.appendChild(tr);
        });
    }
</script>

<!-- Add Device Modal -->
<div class="modal fade" id="addDeviceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/devices" method="POST">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title">Add New Device Type</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Type Name</label>
                        <input type="text" class="form-control" name="type_name" required placeholder="e.g. esp32-smartlamp">
                        <div class="form-text text-muted">A unique identifier for the device type. No spaces.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" name="description" rows="3" placeholder="Optional description..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Device</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Device Modal -->
<div class="modal fade" id="editDeviceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editDeviceForm" onsubmit="submitEditDevice(event)">
                <input type="hidden" id="edit_device_id">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title">Edit Device Type</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Type Name</label>
                        <input type="text" class="form-control" id="edit_type_name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="edit_description" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Device</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
