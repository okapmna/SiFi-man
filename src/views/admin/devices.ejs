<%- include('partials/header') %>
    <%- include('partials/sidebar', { activePage: 'devices' }) %>

        <main class="col-md-9 ms-sm-auto col-lg-10 main-content">
            <div class="page-header">
                <h1 class="h2">Manage Device Types</h1>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addDeviceModal">
                    <i class="bi bi-plus-circle"></i> Add Device Type
                </button>
            </div>

            <!-- Devices Table -->
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Firmwares</th>
                                    <th>GitHub Secret</th>
                                    <th>Created At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="devicesTableBody">
                                <% if (typeof devices==='undefined' || devices.length===0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-4">No device types found</td>
                                    </tr>
                                    <% } else { %>
                                        <% devices.forEach(function(device) { %>
                                            <tr>
                                                <td>
                                                    <%= device.id %>
                                                </td>
                                                <td><span class="badge bg-primary">
                                                        <%= device.type_name %>
                                                    </span></td>
                                                <td>
                                                    <%= device.description || '-' %>
                                                </td>
                                                <td>
                                                    <%= device.firmware_count %>
                                                </td>
                                                <td>
                                                    <% if (device.webhook_secret) { %>
                                                        <div class="input-group input-group-sm" style="min-width:220px">
                                                            <input type="password"
                                                                class="form-control form-control-sm font-monospace secret-input"
                                                                value="<%= device.webhook_secret %>"
                                                                id="secret-<%= device.id %>" readonly>
                                                            <button class="btn btn-outline-secondary btn-sm"
                                                                type="button" title="Show/Hide"
                                                                onclick="toggleSecret(<%= device.id %>)">
                                                                <i class="bi bi-eye" id="eye-<%= device.id %>"></i>
                                                            </button>
                                                            <button class="btn btn-outline-secondary btn-sm"
                                                                type="button" title="Copy"
                                                                onclick="copySecret(<%= device.id %>)">
                                                                <i class="bi bi-clipboard"
                                                                    id="clip-<%= device.id %>"></i>
                                                            </button>
                                                        </div>
                                                        <% } else { %>
                                                            <span class="text-muted fst-italic small">No secret —
                                                                regenerate</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= new Date(device.created_at).toLocaleDateString() %>
                                                </td>
                                                <td>
                                                    <!-- Guide button -->
                                                    <button class="btn btn-sm btn-outline-success me-1 btn-guide-device"
                                                        title="GitHub Actions Guide" data-id="<%= device.id %>"
                                                        data-name="<%= device.type_name %>"
                                                        data-secret="<%= device.webhook_secret || '' %>">
                                                        <i class="bi bi-book"></i>
                                                    </button>
                                                    <!-- Edit button -->
                                                    <button class="btn btn-sm btn-outline-info me-1 btn-edit-device"
                                                        data-id="<%= device.id %>" data-name="<%= device.type_name %>"
                                                        data-desc="<%= device.description || '' %>">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <!-- Regenerate secret -->
                                                    <button class="btn btn-sm btn-outline-warning me-1 btn-regen-secret"
                                                        title="Regenerate API Key" data-id="<%= device.id %>"
                                                        data-name="<%= device.type_name %>">
                                                        <i class="bi bi-arrow-repeat"></i>
                                                    </button>
                                                    <!-- Delete -->
                                                    <% if (device.firmware_count> 0) { %>
                                                        <button class="btn btn-sm btn-outline-danger" disabled
                                                            title="Cannot delete device with firmwares"><i
                                                                class="bi bi-trash"></i></button>
                                                        <% } else { %>
                                                            <button
                                                                class="btn btn-sm btn-outline-danger btn-delete-device"
                                                                data-id="<%= device.id %>"><i
                                                                    class="bi bi-trash"></i></button>
                                                            <% } %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>

        <!-- ===================================================
     Add Device Modal
     =================================================== -->
        <div class="modal fade" id="addDeviceModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form action="/admin/devices" method="POST">
                        <div class="modal-header border-bottom-0">
                            <h5 class="modal-title">Add New Device Type</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Type Name</label>
                                <input type="text" class="form-control" name="type_name" required
                                    placeholder="e.g. esp32-smartlamp">
                                <div class="form-text text-muted">A unique identifier for the device type. No spaces.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="description" rows="3"
                                    placeholder="Optional description..."></textarea>
                            </div>
                            <div class="alert alert-info py-2 small mb-0">
                                <i class="bi bi-key-fill me-1"></i>
                                An <strong>API Key</strong> will be automatically generated for this device.
                            </div>
                        </div>
                        <div class="modal-footer border-top-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Device</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ===================================================
     Edit Device Modal
     =================================================== -->
        <div class="modal fade" id="editDeviceModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form id="editDeviceForm">
                        <input type="hidden" id="edit_device_id">
                        <div class="modal-header border-bottom-0">
                            <h5 class="modal-title">Edit Device Type</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Type Name</label>
                                <input type="text" class="form-control" id="edit_type_name" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" id="edit_description" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-top-0">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Update Device</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ===================================================
     GitHub Actions Guide Modal
     =================================================== -->
        <div class="modal fade" id="guideModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-github me-2"></i>
                            GitHub Actions Setup
                            <span class="badge bg-primary ms-2 fw-normal" id="guide-device-name"></span>
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">
                            Add these <strong>2 secrets</strong> to your GitHub repository under
                            <strong>Settings → Secrets and variables → Actions</strong>.
                            Then include <code>device_type</code> and <code>checksum</code> as required fields in your
                            workflow.
                        </p>

                        <table class="table table-bordered mb-3">
                            <tbody>
                                <tr>
                                    <th style="width:160px;" class="text-nowrap align-middle">Secret name</th>
                                    <th class="align-middle">Value</th>
                                    <th style="width:44px;"></th>
                                </tr>
                                <tr>
                                    <td class="align-middle"><code>OTA_UPLOAD_URL</code></td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm" id="guide-upload-url"
                                            readonly>
                                    </td>
                                    <td class="align-middle text-center">
                                        <button class="btn btn-sm btn-outline-secondary"
                                            onclick="copyGuideEl('guide-upload-url', this)" title="Copy">
                                            <i class="bi bi-clipboard"></i>
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <code>OTA_API_KEY</code>
                                        <small class="d-block text-muted">(or OTA_WEBHOOK_SECRET)</small>
                                    </td>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input type="password" class="form-control form-control-sm font-monospace"
                                                id="guide-api-key" readonly>
                                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                                onclick="toggleEl('guide-api-key', 'guide-eye')">
                                                <i class="bi bi-eye" id="guide-eye"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="align-middle text-center">
                                        <button class="btn btn-sm btn-outline-secondary"
                                            onclick="copyGuideEl('guide-api-key', this)" title="Copy">
                                            <i class="bi bi-clipboard"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered mb-0">
                            <tbody>
                                <tr>
                                    <th colspan="3" class="table-light small text-muted">
                                        <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
                                        Required fields in your workflow <em>(hardcode in the yml, not secrets)</em>
                                    </th>
                                </tr>
                                <tr>
                                    <th style="width:160px;" class="align-middle"><code>device_type</code></th>
                                    <td class="align-middle">
                                        <input type="text" class="form-control form-control-sm font-monospace"
                                            id="guide-device-type" readonly>
                                    </td>
                                    <td style="width:44px;" class="align-middle text-center">
                                        <button class="btn btn-sm btn-outline-secondary"
                                            onclick="copyGuideEl('guide-device-type', this)" title="Copy">
                                            <i class="bi bi-clipboard"></i>
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="align-middle"><code>checksum</code></th>
                                    <td class="align-middle text-muted small fst-italic" colspan="2">
                                        SHA-256 of the firmware binary — compute in the workflow:
                                        <code class="d-block mt-1">sha256sum firmware.bin | awk '{print $1}'</code>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // ---- Toggle secret visibility ----
            function toggleSecret(id) {
                const input = document.getElementById('secret-' + id);
                const eye = document.getElementById('eye-' + id);
                if (input.type === 'password') {
                    input.type = 'text';
                    eye.className = 'bi bi-eye-slash';
                } else {
                    input.type = 'password';
                    eye.className = 'bi bi-eye';
                }
            }

            function copySecret(id) {
                const input = document.getElementById('secret-' + id);
                const clip = document.getElementById('clip-' + id);
                navigator.clipboard.writeText(input.value).then(() => {
                    clip.className = 'bi bi-check2';
                    setTimeout(() => { clip.className = 'bi bi-clipboard'; }, 1500);
                });
            }

            // ---- Generic copy / toggle helpers for guide modal ----
            function copyGuideEl(elId, btn) {
                const el = document.getElementById(elId);
                navigator.clipboard.writeText(el.value).then(() => {
                    const icon = btn.querySelector('i');
                    if (icon) {
                        icon.className = 'bi bi-check2';
                        setTimeout(() => { icon.className = 'bi bi-clipboard'; }, 1500);
                    }
                });
            }

            function toggleEl(inputId, eyeId) {
                const input = document.getElementById(inputId);
                const eye = document.getElementById(eyeId);
                if (input.type === 'password') {
                    input.type = 'text';
                    eye.className = 'bi bi-eye-slash';
                } else {
                    input.type = 'password';
                    eye.className = 'bi bi-eye';
                }
            }

            // ---- Edit device buttons ----
            document.querySelectorAll('.btn-edit-device').forEach(function (btn) {
                btn.addEventListener('click', function () { editDevice(this); });
            });

            // ---- Delete device buttons ----
            document.querySelectorAll('.btn-delete-device').forEach(function (btn) {
                btn.addEventListener('click', function () { deleteDevice(this.getAttribute('data-id')); });
            });

            // ---- Edit device form submit ----
            var editForm = document.getElementById('editDeviceForm');
            if (editForm) {
                editForm.addEventListener('submit', function (e) { submitEditDevice(e); });
            }

            // ---- Regenerate secret ----
            document.querySelectorAll('.btn-regen-secret').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const id = this.getAttribute('data-id');
                    const name = this.getAttribute('data-name');
                    if (!confirm(`Regenerate API Key for "${name}"?\n\nThe old key will stop working immediately.`)) return;

                    fetch(`/admin/devices/${id}/regenerate-secret`, { method: 'POST' })
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                const secretInput = document.getElementById('secret-' + id);
                                if (secretInput) {
                                    secretInput.value = data.secret;
                                    secretInput.type = 'text';
                                    document.getElementById('eye-' + id).className = 'bi bi-eye-slash';
                                    setTimeout(() => {
                                        if (secretInput) secretInput.type = 'password';
                                        const eye = document.getElementById('eye-' + id);
                                        if (eye) eye.className = 'bi bi-eye';
                                    }, 8000);
                                } else {
                                    location.reload();
                                }
                                alert(`New API Key for "${name}" has been generated!\n\nIt is now visible in the row for 8 seconds. Copy it immediately.`);
                            } else {
                                alert('Failed to regenerate secret: ' + (data.error || 'Unknown error'));
                            }
                        })
                        .catch(() => alert('Network error while regenerating secret'));
                });
            });

            // ---- GitHub Actions Guide Modal ----
            document.querySelectorAll('.btn-guide-device').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const deviceName = this.getAttribute('data-name');
                    const secret = this.getAttribute('data-secret');

                    document.getElementById('guide-device-name').textContent = deviceName;
                    document.getElementById('guide-api-key').value = secret || '(no secret — please regenerate)';
                    document.getElementById('guide-device-type').value = deviceName;
                    document.getElementById('guide-upload-url').value = window.location.origin + '/api/upload';

                    // reset eye icon
                    const eye = document.getElementById('guide-eye');
                    if (eye) eye.className = 'bi bi-eye';
                    const apiKeyInput = document.getElementById('guide-api-key');
                    if (apiKeyInput) apiKeyInput.type = 'password';

                    new bootstrap.Modal(document.getElementById('guideModal')).show();
                });
            });
        </script>

        <%- include('partials/footer') %>