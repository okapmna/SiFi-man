<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'logs' }) %>

<%
const BADGE_MAP = {
    login:                  { label: 'Login',              cls: 'bg-success' },
    login_failed:           { label: 'Login Failed',       cls: 'bg-danger' },
    logout:                 { label: 'Logout',             cls: 'bg-secondary' },
    password_changed:       { label: 'Password Changed',   cls: 'bg-warning text-dark' },
    password_change_failed: { label: 'Password Change Failed', cls: 'bg-danger' },
    device_created:         { label: 'Device Created',     cls: 'bg-info text-dark' },
    device_updated:         { label: 'Device Updated',     cls: 'bg-info text-dark' },
    device_deleted:         { label: 'Device Deleted',     cls: 'bg-danger' },
    firmware_uploaded:      { label: 'Firmware Uploaded',  cls: 'bg-primary' },
    firmware_uploaded_active: { label: 'Firmware Uploaded', cls: 'bg-primary' },
    firmware_uploaded_api:  { label: 'Firmware Uploaded',  cls: 'bg-primary' },
    firmware_activated:     { label: 'Firmware Activated', cls: 'bg-success' },
    firmware_deleted:       { label: 'Firmware Deleted',   cls: 'bg-danger' },
};

const FILTER_ACTIONS = [
    { value: 'login',               label: 'Login' },
    { value: 'login_failed',        label: 'Login Failed' },
    { value: 'logout',              label: 'Logout' },
    { value: 'password_changed',    label: 'Password Changed' },
    { value: 'password_change_failed', label: 'Password Change Failed' },
    { value: 'device_created',      label: 'Device Created' },
    { value: 'device_updated',      label: 'Device Updated' },
    { value: 'device_deleted',      label: 'Device Deleted' },
    { value: 'firmware_uploaded',   label: 'Firmware Uploaded' },
    { value: 'firmware_activated',  label: 'Firmware Activated' },
    { value: 'firmware_deleted',    label: 'Firmware Deleted' },
];
%>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2"><i class="bi bi-journal-text"></i> Audit Logs</h1>
    </div>

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="GET" action="/admin/logs" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Action</label>
                    <select name="action" class="form-select">
                        <option value="">All Actions</option>
                        <% FILTER_ACTIONS.forEach(function(a) { %>
                            <option value="<%= a.value %>" <%= filterAction === a.value ? 'selected' : '' %>><%= a.label %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Entity Type</label>
                    <select name="entity_type" class="form-select">
                        <option value="">All Types</option>
                        <option value="device_type" <%= filterEntity === 'device_type' ? 'selected' : '' %>>Device Type</option>
                        <option value="firmware" <%= filterEntity === 'firmware' ? 'selected' : '' %>>Firmware</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ul me-2"></i>Activity Log</span>
            <span class="badge bg-secondary"><%= total %> entries</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>Details</th>
                            <th>Performed By</th>
                            <th>IP Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (logs.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox me-2"></i>No logs found
                                </td>
                            </tr>
                        <% } else { %>
                            <% logs.forEach(function(log) { %>
                                <% var cfg = BADGE_MAP[log.action] || { label: log.action, cls: 'bg-secondary' }; %>
                                <tr>
                                    <td class="text-nowrap small">
                                        <%= new Date(log.created_at).toLocaleString() %>
                                    </td>
                                    <td>
                                        <span class="badge <%= cfg.cls %>"><%= cfg.label %></span>
                                    </td>
                                    <td class="small">
                                        <%= log.entity_type ? log.entity_type + ' #' + log.entity_id : '-' %>
                                    </td>
                                    <td class="small"><%= log.details || '-' %></td>
                                    <td><%= log.performed_by || '-' %></td>
                                    <td class="small text-muted font-monospace"><%= log.ip_address || '-' %></td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
        <% if (totalPages > 1) { %>
            <div class="card-footer">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= page - 1 %><%= filterAction ? '&action=' + encodeURIComponent(filterAction) : '' %><%= filterEntity ? '&entity_type=' + encodeURIComponent(filterEntity) : '' %>">Previous</a>
                        </li>
                        <% for (let p = 1; p <= totalPages; p++) { %>
                            <li class="page-item <%= p === page ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= p %><%= filterAction ? '&action=' + encodeURIComponent(filterAction) : '' %><%= filterEntity ? '&entity_type=' + encodeURIComponent(filterEntity) : '' %>"><%= p %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= page + 1 %><%= filterAction ? '&action=' + encodeURIComponent(filterAction) : '' %><%= filterEntity ? '&entity_type=' + encodeURIComponent(filterEntity) : '' %>">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>
