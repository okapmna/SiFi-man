<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'settings' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2"><i class="bi bi-gear"></i> Settings</h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Nav tabs -->
    <ul class="nav nav-tabs mb-4" id="settingsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="account-tab" data-bs-toggle="tab" data-bs-target="#account" type="button" role="tab">
                <i class="bi bi-person-circle me-1"></i> My Account
            </button>
        </li>
        <% if (permissions && permissions.edit_user) { %>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                <i class="bi bi-people me-1"></i> User Manager
            </button>
        </li>
        <% } %>
    </ul>

    <div class="tab-content" id="settingsTabsContent">
        <!-- ==============================================
             ACCOUNT TAB
             ============================================== -->
        <div class="tab-pane fade show active" id="account" role="tabpanel" tabindex="0">
            <!-- Account Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-info-circle me-2"></i>Account Information
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Username</dt>
                                <dd class="col-sm-8"><%= adminInfo ? adminInfo.username : 'N/A' %></dd>
                                <dt class="col-sm-4">Joined</dt>
                                <dd class="col-sm-8"><%= adminInfo ? new Date(adminInfo.created_at).toLocaleString() : 'N/A' %></dd>
                            </dl>
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <div class="p-3 bg-light rounded border">
                                <h6 class="mb-2 text-muted">My Permissions</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    <% if (permissions && Object.keys(permissions).length > 0) { %>
                                        <% Object.keys(permissions).forEach(key => { %>
                                            <% if (permissions[key]) { %>
                                                <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i><%= key.replace('_', ' ') %></span>
                                            <% } %>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted small fst-italic">No permissions data</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <!-- Change Password -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-key me-2"></i>Change Password
                        </div>
                        <div class="card-body">
                            <form action="/admin/settings/password" method="POST" autocomplete="off">
                                <div class="mb-3">
                                    <label for="current_password" class="form-label">Current Password</label>
                                    <input type="password" class="form-control" id="current_password" name="current_password" required>
                                </div>
                                <div class="mb-3">
                                    <label for="new_password" class="form-label">New Password</label>
                                    <input type="password" class="form-control" id="new_password" name="new_password" required minlength="8">
                                    <div class="form-text">Minimum 8 characters</div>
                                </div>
                                <div class="mb-4">
                                    <label for="confirm_password" class="form-label">Confirm New Password</label>
                                    <input type="password" class="form-control" id="confirm_password" name="confirm_password" required minlength="8">
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-lg"></i> Update Password
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <!-- Logout -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <i class="bi bi-box-arrow-right me-2 text-danger"></i>Session
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3 small">End your current session securely.</p>
                            <form action="/admin/logout" method="POST">
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <% if (permissions && permissions.edit_user) { %>
        <!-- ==============================================
             USER MANAGER TAB
             ============================================== -->
        <div class="tab-pane fade" id="users" role="tabpanel" tabindex="0">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-people me-2"></i>Manage Admin Users</span>
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="bi bi-person-plus"></i> Add User
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Permissions</th>
                                    <th>Joined</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof allUsers !== 'undefined' && allUsers.length > 0) { %>
                                    <% allUsers.forEach(u => { %>
                                    <tr>
                                        <td><%= u.id %></td>
                                        <td><strong><%= u.username %></strong>
                                            <% if (u.id === adminInfo.id) { %> <span class="badge bg-secondary ms-1">You</span> <% } %>
                                        </td>
                                        <td style="max-width: 300px;">
                                            <div class="d-flex flex-wrap gap-1">
                                                <% const p = u.permissions || {}; %>
                                                <span class="badge <%= p.upload ? 'bg-success' : 'bg-light text-muted' %>" title="Upload Firmware">Up</span>
                                                <span class="badge <%= p.activate ? 'bg-success' : 'bg-light text-muted' %>" title="Activate Firmware">Act</span>
                                                <span class="badge <%= p.remove ? 'bg-success' : 'bg-light text-muted' %>" title="Remove Firmware/Device">Rem</span>
                                                <span class="badge <%= p.edit_detail ? 'bg-success' : 'bg-light text-muted' %>" title="Edit Device/Firmware Detail">EDet</span>
                                                <span class="badge <%= p.edit_user ? 'bg-warning text-dark' : 'bg-light text-muted' %>" title="Edit Users">EUsr</span>
                                            </div>
                                        </td>
                                        <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-info me-1" title="Edit Username" onclick="openEditUsername(<%= u.id %>, '<%= u.username %>')">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning me-1" title="Edit Permissions" onclick="openEditPermissions(<%= u.id %>, '<%= u.username %>', <%= JSON.stringify(u.permissions || {}) %>)" <%= u.id === adminInfo.id ? 'disabled' : '' %>>
                                                <i class="bi bi-shield-lock"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" title="Delete User" onclick="deleteUser(<%= u.id %>, '<%= u.username %>')" <%= u.id === adminInfo.id ? 'disabled' : '' %>>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
    </div>
</main>

<% if (permissions && permissions.edit_user) { %>
<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="addUserForm">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Admin User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" required minlength="8">
                    </div>
                    <div class="alert alert-info small py-2 mb-0">
                        New user will have all permissions by default <strong>except</strong> User Manager access.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save User</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Username Modal -->
<div class="modal fade" id="editUsernameModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editUsernameForm">
                <input type="hidden" name="user_id" id="eu_user_id">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Username</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" id="eu_username" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Permissions Modal -->
<div class="modal fade" id="editPermissionsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editPermissionsForm">
                <input type="hidden" name="user_id" id="ep_user_id">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Permissions — <span id="ep_username" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="perm_upload" name="upload">
                        <label class="form-check-label" for="perm_upload"><strong>Upload</strong> <span class="text-muted small">— Can upload firmware</span></label>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="perm_activate" name="activate">
                        <label class="form-check-label" for="perm_activate"><strong>Activate</strong> <span class="text-muted small">— Can set firmware as active</span></label>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="perm_remove" name="remove">
                        <label class="form-check-label" for="perm_remove"><strong>Remove</strong> <span class="text-muted small">— Can delete firmware and device types</span></label>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="perm_edit_detail" name="edit_detail">
                        <label class="form-check-label" for="perm_edit_detail"><strong>Edit Details</strong> <span class="text-muted small">— Can edit device info and regenerate API keys</span></label>
                    </div>
                    <hr>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="perm_edit_user" name="edit_user">
                        <label class="form-check-label" for="perm_edit_user"><strong>Manage Users</strong> <span class="text-danger small">— Can add/edit/delete admin users</span></label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Permissions</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Tab persistence
document.addEventListener("DOMContentLoaded", function() {
    var triggerTabList = [].slice.call(document.querySelectorAll('#settingsTabs button'))
    triggerTabList.forEach(function (triggerEl) {
        var tabTrigger = new bootstrap.Tab(triggerEl)
        triggerEl.addEventListener('click', function (event) {
            event.preventDefault()
            tabTrigger.show()
            localStorage.setItem('activeSettingsTab', triggerEl.getAttribute('id'))
        })
    })

    var activeTabId = localStorage.getItem('activeSettingsTab');
    if (activeTabId) {
        var tab = document.getElementById(activeTabId);
        if (tab) new bootstrap.Tab(tab).show();
    }
});

// Add User
document.getElementById('addUserForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    try {
        const res = await fetch('/admin/settings/users', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                username: e.target.username.value,
                password: e.target.password.value
            })
        });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Error: ' + data.error);
    } catch (err) {
        alert('Network error');
    }
    btn.disabled = false;
});

// Edit Username
function openEditUsername(id, username) {
    document.getElementById('eu_user_id').value = id;
    document.getElementById('eu_username').value = username;
    new bootstrap.Modal(document.getElementById('editUsernameModal')).show();
}

document.getElementById('editUsernameForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('eu_user_id').value;
    const username = document.getElementById('eu_username').value;
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    try {
        const res = await fetch(`/admin/settings/users/${id}/username`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username })
        });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Error: ' + data.error);
    } catch (err) {
        alert('Network error');
    }
    btn.disabled = false;
});

// Edit Permissions
function openEditPermissions(id, username, perms) {
    document.getElementById('ep_user_id').value = id;
    document.getElementById('ep_username').textContent = username;
    document.getElementById('perm_upload').checked = !!perms.upload;
    document.getElementById('perm_activate').checked = !!perms.activate;
    document.getElementById('perm_remove').checked = !!perms.remove;
    document.getElementById('perm_edit_detail').checked = !!perms.edit_detail;
    document.getElementById('perm_edit_user').checked = !!perms.edit_user;
    new bootstrap.Modal(document.getElementById('editPermissionsModal')).show();
}

document.getElementById('editPermissionsForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('ep_user_id').value;
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    
    const permissions = {
        upload: document.getElementById('perm_upload').checked,
        activate: document.getElementById('perm_activate').checked,
        remove: document.getElementById('perm_remove').checked,
        edit_detail: document.getElementById('perm_edit_detail').checked,
        edit_user: document.getElementById('perm_edit_user').checked
    };

    try {
        const res = await fetch(`/admin/settings/users/${id}/permissions`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ permissions })
        });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Error: ' + data.error);
    } catch (err) {
        alert('Network error');
    }
    btn.disabled = false;
});

// Delete User
async function deleteUser(id, username) {
    if (!confirm(`Are you sure you want to delete user "${username}"?`)) return;
    try {
        const res = await fetch(`/admin/settings/users/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Error: ' + data.error);
    } catch (err) {
        alert('Network error');
    }
}
</script>
<% } %>

<%- include('partials/footer') %>
