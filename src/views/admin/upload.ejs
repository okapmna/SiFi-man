<%- include('partials/header') %>
<%- include('partials/sidebar', { activePage: 'upload' }) %>

<main class="col-md-9 ms-sm-auto col-lg-10 main-content">
    <div class="page-header">
        <h1 class="h2"><i class="bi bi-cloud-arrow-up me-2"></i>Upload Firmware</h1>
        <a href="/admin/firmwares" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Firmwares
        </a>
    </div>

    <!-- Flash Messages -->
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-file-earmark-binary me-2"></i>Firmware Upload Form
                </div>
                <div class="card-body p-4">
                    <form action="/admin/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

                        <!-- Device Type -->
                        <div class="mb-4">
                            <label for="device_type" class="form-label fw-semibold">
                                <i class="bi bi-cpu me-1"></i> Device Type <span class="text-danger">*</span>
                            </label>
                            <% if (deviceTypes.length === 0) { %>
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    No device types registered yet. <a href="/admin/devices" class="alert-link">Add one first</a>.
                                </div>
                                <select class="form-select" id="device_type" name="device_type" disabled>
                                    <option>No device types available</option>
                                </select>
                            <% } else { %>
                                <select class="form-select" id="device_type" name="device_type" required>
                                    <option value="" disabled selected>Select a device type...</option>
                                    <% deviceTypes.forEach(function(dt) { %>
                                        <option value="<%= dt.type_name %>"><%= dt.type_name %></option>
                                    <% }); %>
                                </select>
                            <% } %>
                        </div>

                        <!-- Version -->
                        <div class="mb-4">
                            <label for="version" class="form-label fw-semibold">
                                <i class="bi bi-tag me-1"></i> Version <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" id="version" name="version"
                                   placeholder="e.g. 1.2.3 or v2.0.0-beta"
                                   pattern="[a-zA-Z0-9._\-]+" required>
                            <div class="form-text">Use semantic versioning. Only alphanumeric, dots, hyphens, underscores.</div>
                        </div>

                        <!-- Notes -->
                        <div class="mb-4">
                            <label for="notes" class="form-label fw-semibold">
                                <i class="bi bi-journal-text me-1"></i> Release Notes
                            </label>
                            <textarea class="form-control" id="notes" name="notes" rows="3"
                                      placeholder="Optional: describe what changed in this version..."></textarea>
                        </div>

                        <!-- File Picker -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-file-earmark-binary me-1"></i> Firmware File (.bin) <span class="text-danger">*</span>
                            </label>
                            <div id="dropZone" class="drop-zone">
                                <i class="bi bi-cloud-upload fs-2 mb-2 text-muted d-block"></i>
                                <span id="dropZoneText" class="text-muted">Click to select .bin file</span>
                            </div>
                            <input type="file" id="firmware" name="firmware" accept=".bin" required class="d-none">
                        </div>

                        <!-- Source Repo -->
                        <div class="mb-4">
                            <label for="source_repo" class="form-label fw-semibold">
                                <i class="bi bi-git me-1"></i> Source Repository
                            </label>
                            <input type="text" class="form-control" id="source_repo" name="source_repo"
                                   placeholder="e.g. https://github.com/owner/repo">
                            <div class="form-text">Optional: GitHub repository URL where this firmware was built.</div>
                        </div>

                        <!-- Set Active -->
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="set_active" name="set_active" checked>
                                <label class="form-check-label" for="set_active">
                                    <strong>Set as Active Firmware</strong>
                                    <span class="text-muted small d-block">
                                        If enabled, this firmware will immediately be served to devices on OTA check.
                                        Previous active firmware will be deactivated.
                                    </span>
                                </label>
                            </div>
                        </div>

                        <!-- Submit -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn"
                                    <% if (deviceTypes.length === 0) { %>disabled<% } %>>
                                <i class="bi bi-cloud-arrow-up me-2"></i>Upload Firmware
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <!-- Info Card -->
            <div class="card mt-3">
                <div class="card-body p-3">
                    <h6 class="text-muted mb-2"><i class="bi bi-info-circle me-1"></i> Notes</h6>
                    <ul class="text-muted small mb-0">
                        <li>Only <strong>.bin</strong> files are accepted.</li>
                        <li><strong>SHA256</strong> checksum is calculated automatically after upload.</li>
                        <li>File is stored in <code>firmware_storage/{device_type}/</code>.</li>
                        <li>Each device type can have only <strong>one active</strong> firmware at a time.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</main>



<script>
    function updateDropZone(input) {
        const zone = document.getElementById('dropZone');
        const text = document.getElementById('dropZoneText');
        if (input.files && input.files[0]) {
            const file = input.files[0];
            const size = file.size < 1024 * 1024
                ? (file.size / 1024).toFixed(1) + ' KB'
                : (file.size / (1024 * 1024)).toFixed(2) + ' MB';
            zone.classList.remove('active');
            zone.classList.add('file-selected');
            text.innerHTML = '<i class="bi bi-file-earmark-check text-success me-2"></i><strong>' + file.name + '</strong> (' + size + ')';
        } else {
            zone.classList.remove('file-selected');
            text.textContent = 'Click to select .bin file';
        }
    }

    // Drag & drop support
    var dropZone = document.getElementById('dropZone');
    dropZone.addEventListener('click', function() {
        document.getElementById('firmware').click();
    });
    document.getElementById('firmware').addEventListener('change', function() {
        updateDropZone(this);
    });
    dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.classList.add('active');
    });
    dropZone.addEventListener('dragleave', function() {
        dropZone.classList.remove('active');
    });
    dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        const fileInput = document.getElementById('firmware');
        fileInput.files = e.dataTransfer.files;
        updateDropZone(fileInput);
    });

    // Loading state on submit
    document.getElementById('uploadForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Uploading...';
    });
</script>

<%- include('partials/footer') %>
